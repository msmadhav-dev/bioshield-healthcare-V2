generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Product {
  id         String   @id @default(cuid())
  name       String
  category   String   @default("general")
  frontImage String
  backImage  String?
  createdAt  DateTime @default(now())

  @@map("products")
}

model Category {
  id           String   @id @default(cuid())
  name         String
  image        String?
  gradientFrom String?
  gradientTo   String?
  imageSize    Int      @default(68)
  createdAt    DateTime @default(now())

  @@map("categories")
}
model Advertisement {
  id            String   @id @default(cuid())
  badge         String?
  topCaption    String?
  heading       String
  productName   String
  linkUrl       String?
  image         String?
  createdAt     DateTime @default(now())
  imageSize     Int      @default(100) // desktop image size %
  imageSizeMobile     Int @default(100)
  titleSizeDesktop    Int @default(100)
  titleSizeMobile     Int @default(100)
  captionSizeDesktop  Int @default(100)
  captionSizeMobile   Int @default(100)
  buttonSizeDesktop   Int @default(100)
  buttonSizeMobile    Int @default(100)
  imageOffsetX  Int      @default(0) // percentage point offset, drag-positioned in admin
  imageOffsetY  Int      @default(0)
  imageOffsetXMobile Int @default(0) // separate drag position for the mobile preview
  imageOffsetYMobile Int @default(0)
  slot          Int      @default(1)
  subText       String?
  theme         String   @default("orange")
  buttonText    String   @default("Buy now")

  @@map("advertisements")
}

model ShopProduct {
  id                  String   @id @default(cuid())
  name                String
  slug                String   @unique
  badge               String?
  badgeColor          String   @default("red")
  cardColor           String   @default("purple") // "purple" | "orange" — listing-card image panel background
  mainImage           String
  images              String[]
  categoryId          String?
  sectionId           String?
  sectionOrder        Int      @default(0)
  doctorOffer         String?
  productDetails      String?
  manufacturerDetails String?
  benefits              String?
  productDescription    String?
  offers                String[]
  frequentlyBoughtIds   String[]
  unit                String?
  availableUnits      String[]
  stock               Int?
  createdAt           DateTime @default(now())

  // ── Pricing — split by customer vs doctor ──
  customerMrp          Float
  customerOfferPercent Float?  // e.g. 10 = 10% off; if unset, MRP shown struck-through twice (attraction effect)
  doctorMrp             Float?
  doctorPtrPrice         Float?
  taxPercent             Float? // applied only to doctor PTR price, only in order summary — never shown on product cards/pages

  // ── Delivery weight calc ──
  productType   String @default("OTHER") // "TABLET" | "GEL" | "SYRUP" | "OTHER" — TABLET is excluded from weight calc
  weightInGrams Float? // always stored canonically in grams
  weightUnit    String @default("G") // "G" | "ML" | "L" — the unit the admin originally entered, kept for display when re-editing

  cartItems CartItem[]
  likedBy   LikedProduct[]

  @@map("shop_products")
}

model ShopSection {
  id                    String   @id @default(cuid())
  name                  String
  subtitle              String?
  order                 Int      @default(0)
  createdAt             DateTime @default(now())
  availableUnits        String[]
  productDetailSections Json?
  stock                 Int?
  unit                  String?

  @@map("shop_sections")
}

model SiteSettings {
  id                            String   @id @default("global")
  deliveryChargePerKg           Float    @default(30)
  customerFreeDeliveryThreshold Float    @default(500)
  doctorFreeDeliveryThreshold   Float    @default(1000)
  deliveryCutoffHour            Int      @default(13) // 24h format — 13 = 1pm
  deliveryFastDaysMin           Int      @default(1)  // ordered before cutoff
  deliveryFastDaysMax           Int      @default(2)
  deliverySlowDaysMin           Int      @default(2)  // ordered after cutoff
  deliverySlowDaysMax           Int      @default(3)
  updatedAt                     DateTime @updatedAt

  @@map("site_settings")
}

model DoctorVerification {
  id               String    @id @default(cuid())
  userId           String    @unique
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  doctorName       String
  hospitalName     String
  registerNo       String?
  registerProofUrl String?
  dlNo             String?
  dlProofUrl       String?
  address          String
  status           String    @default("PENDING") // "PENDING" | "APPROVED" | "REJECTED"
  rejectionReason  String?
  createdAt        DateTime  @default(now())
  reviewedAt       DateTime?

  @@map("doctor_verifications")
}

model User {
  id            String   @id @default(cuid())
  name          String
  email         String?
  phone         String   @unique
  role          String   // "CUSTOMER" | "DOCTOR"
  hospitalName  String?
  gender        String   // "MALE" | "FEMALE" | "OTHER"
  age           Int
  walletBalance Float    @default(0)
  appliedCouponCode String?
  createdAt     DateTime @default(now())

  addresses Address[]
  doctorVerification DoctorVerification?
  cartItems CartItem[]
  likedProducts LikedProduct[]

  @@map("users")
}

model LikedProduct {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  shopProductId String
  shopProduct   ShopProduct @relation(fields: [shopProductId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())

  @@unique([userId, shopProductId])
  @@map("liked_products")
}

model CartItem {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  shopProductId String
  shopProduct   ShopProduct @relation(fields: [shopProductId], references: [id], onDelete: Cascade)
  selectedUnit  String?  // which pack size variant, if the product has availableUnits
  quantity      Int      @default(1)
  createdAt     DateTime @default(now())

  @@unique([userId, shopProductId, selectedUnit])
  @@map("cart_items")
}

model Address {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label     String
  doorNo    String
  street    String
  cityTown  String
  pincode   String
  district  String
  state     String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("addresses")
}