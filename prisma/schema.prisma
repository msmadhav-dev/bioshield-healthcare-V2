generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Product {
  id          String   @id @default(cuid())
  name        String
  category    String   @default("general")
  frontImage  String
  backImage   String?
  createdAt   DateTime @default(now())

  @@map("products")
}

model Category {
  id        String   @id @default(cuid())
  name      String
  image     String?
  createdAt DateTime @default(now())

  @@map("categories")
}

model Advertisement {
  id          String   @id @default(cuid())
  slot        Int      @default(1)    // 1=green main, 2=blue top-right, 3=navy text, 4=pink bottom-right
  badge       String?
  topCaption  String?
  heading     String
  subText     String?
  productName String
  image       String?
  imageSize   Int      @default(100)  // 60-200 percentage
  createdAt   DateTime @default(now())

  @@map("advertisements")
}

model ShopProduct {
  id                  String   @id @default(cuid())
  name                String
  slug                String   @unique
  price               Float?
  offerPrice          Float
  badge               String?
  badgeColor          String   @default("red")
  mainImage           String
  images              String[]
  categoryId          String?
  sectionId           String?
  sectionOrder        Int      @default(0)
  doctorOffer         String?
  productDetails      String?
  manufacturerDetails String?
  createdAt           DateTime @default(now())

  @@map("shop_products")
}

model ShopSection {
  id        String   @id @default(cuid())
  name      String
  subtitle  String?
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@map("shop_sections")
}