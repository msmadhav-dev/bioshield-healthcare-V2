generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Product {
  id         String   @id @default(cuid())
  name       String
  category   String   @default("general")
  frontImage String
  backImage  String?
  createdAt  DateTime @default(now())

  @@map("products")
}

model Category {
  id        String   @id @default(cuid())
  name      String
  image     String?
  createdAt DateTime @default(now())

  @@map("categories")
}

model Advertisement {
  id          String   @id @default(cuid())
  badge       String?
  topCaption  String?
  heading     String
  productName String
  image       String?
  createdAt   DateTime @default(now())
  imageSize   Int      @default(100)
  slot        Int      @default(1)
  subText     String?

  @@map("advertisements")
}

model ShopProduct {
  id                  String   @id @default(cuid())
  name                String
  slug                String   @unique
  price               Float?
  offerPrice          Float
  badge               String?
  badgeColor          String   @default("red")
  mainImage           String
  images              String[]
  categoryId          String?
  sectionId           String?
  sectionOrder        Int      @default(0)
  doctorOffer         String?
  productDetails      String?
  manufacturerDetails String?
  benefits              String?
  productDescription    String?
  offers                String[]
  frequentlyBoughtIds   String[]
  unit                String?
  availableUnits      String[]
  stock               Int?
  createdAt           DateTime @default(now())

  @@map("shop_products")
}

model ShopSection {
  id                    String   @id @default(cuid())
  name                  String
  subtitle              String?
  order                 Int      @default(0)
  createdAt             DateTime @default(now())
  availableUnits        String[]
  productDetailSections Json?
  stock                 Int?
  unit                  String?

  @@map("shop_sections")
}

model SiteSettings {
  id                    String   @id @default("global")
  freeDeliveryThreshold Float    @default(400)
  updatedAt             DateTime @updatedAt

  @@map("site_settings")
}

model User {
  id           String   @id @default(cuid())
  name         String
  phone        String   @unique
  role         String   // "CUSTOMER" | "DOCTOR"
  hospitalName String?
  gender       String   // "MALE" | "FEMALE" | "OTHER"
  age          Int
  createdAt    DateTime @default(now())

  @@map("users")
}