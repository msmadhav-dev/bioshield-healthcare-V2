generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Product {
  id          String   @id @default(cuid())
  name        String
  category    String   @default("general")
  frontImage  String
  backImage   String?
  createdAt   DateTime @default(now())

  @@map("products")
}